          },
          "editorMode": "code",
          "expr": "sum(kubelet_running_pods{cluster=~\"$cluster\"} or kubelet_running_pod_count{cluster=~\"$cluster\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\",resource=\"pods\"}) * 100",
          "legendFormat": "pods",
          "refId": "A",
          "range": true,
          "instant": false
