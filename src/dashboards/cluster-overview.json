        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "count(kube_namespace_status_phase{cluster=~\"$cluster\",phase=\"Active\"})",
          "legendFormat": "ns",
          "refId": "A",
          "range": true,
          "instant": false
