{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "PVC/PV capacity, inodes, fill forecast and inventory. Needs kubelet volume metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Capacity",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "PVC usage %",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "(1 - kubelet_volume_stats_available_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"} / kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}) * 100",
          "legendFormat": "{{namespace}}/{{persistentvolumeclaim}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "id": 3,
      "title": "Inodes usage %",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "(1 - kubelet_volume_stats_inodes_free{cluster=~\"$cluster\",namespace=~\"$namespace\"} / kubelet_volume_stats_inodes{cluster=~\"$cluster\",namespace=~\"$namespace\"}) * 100",
          "legendFormat": "{{namespace}}/{{persistentvolumeclaim}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "id": 4,
      "title": "PVC used vs capacity",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "kubelet_volume_stats_used_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "legendFormat": "__auto",
          "refId": "B",
          "range": false,
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "kubelet_volume_stats_available_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "legendFormat": "__auto",
          "refId": "D",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 5,
      "title": "Forecast & inventory",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "panels": []
    },
    {
      "id": 6,
      "title": "Predicted free space in 4 days (predict_linear)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "predict_linear(kubelet_volume_stats_available_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}[6h], 4*24*3600)",
          "legendFormat": "{{namespace}}/{{persistentvolumeclaim}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Negative \u21d2 the volume is predicted to fill within 4 days."
    },
    {
      "id": 7,
      "title": "PersistentVolumes by phase",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum by (phase)(kube_persistentvolume_status_phase{cluster=~\"$cluster\"})",
          "legendFormat": "{{phase}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 8,
      "title": "PVCs by storage class",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "kube_persistentvolumeclaim_info{cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      }
    }
  ],
  "refresh": "1m",
  "revision": 1,
  "schemaVersion": 39,
  "tags": [
    "kubernetes",
    "KubeMeridian",
    "storage",
    "pvc"
  ],
  "templating": {
    "list": [
      {
        "name": "PromDs",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "includeAll": false,
        "multi": false,
        "options": [],
        "queryValue": "",
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": {
          "type": "prometheus",
          "uid": "${PromDs}"
        },
        "definition": "label_values(kube_node_info, cluster)",
        "query": {
          "query": "label_values(kube_node_info, cluster)",
          "refId": "cluster"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
        "multi": false,
        "hide": 0,
        "options": [],
        "skipUrlSync": false,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        }
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${PromDs}"
        },
        "definition": "label_values(kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\"}, namespace)",
        "query": {
          "query": "label_values(kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\"}, namespace)",
          "refId": "namespace"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "options": [],
        "skipUrlSync": false,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "KubeMeridian \u2014 Storage",
  "uid": "kubemeridian-storage",
  "weekStart": ""
}
