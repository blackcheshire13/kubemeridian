{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FinOps: estimated cost (requests x price list, or OpenCost), waste and right-sizing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Efficiency",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Cluster CPU efficiency",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",container!=\"\", container!=\"POD\"}[$__rate_interval])) / sum(kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"cpu\"}) * 100",
          "legendFormat": "cpu eff",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "description": "Actual CPU usage as a share of requested CPU. Low = over-provisioned."
    },
    {
      "id": 3,
      "title": "Cluster memory efficiency",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum(container_memory_working_set_bytes{cluster=~\"$cluster\",container!=\"\", container!=\"POD\"}) / sum(kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"memory\"}) * 100",
          "legendFormat": "mem eff",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Est. cluster cost / month",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "(sum(kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"cpu\"}) * ${cpu_hourly} + sum(kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"memory\"})/1024/1024/1024 * ${mem_hourly}) * 730",
          "legendFormat": "usd",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "none",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "description": "Estimated from requests x the configurable price list (set OpenCost-equivalent rates above)."
    },
    {
      "id": 5,
      "title": "Node hourly cost (OpenCost)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum(node_total_hourly_cost)",
          "legendFormat": "usd/h",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "none",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "description": "Real OpenCost metric. Empty unless the OpenCost exporter is installed."
    },
    {
      "id": 6,
      "title": "Estimated cost by namespace",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 7,
      "title": "Est. monthly cost by namespace",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "(sum by (namespace)(kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"cpu\"}) * ${cpu_hourly} + sum by (namespace)(kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"memory\"})/1024/1024/1024 * ${mem_hourly}) * 730",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true
      }
    },
    {
      "id": 8,
      "title": "Waste (requested minus used)",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "panels": []
    },
    {
      "id": 9,
      "title": "CPU waste by namespace (cores)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum by (namespace)(kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"cpu\"}) - sum by (namespace)(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\", container!=\"POD\"}[$__rate_interval]))",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 10,
      "title": "Memory waste by namespace",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum by (namespace)(kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"memory\"}) - sum by (namespace)(container_memory_working_set_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\", container!=\"POD\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "title": "Right-sizing candidates",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "panels": []
    },
    {
      "id": 12,
      "title": "Over-provisioned: CPU usage < 50% of request",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "(sum by (namespace,pod,container)(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\", container!=\"POD\"}[$__rate_interval])) / sum by (namespace,pod,container)(kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"cpu\"})) < 0.5",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "description": "Ratio of CPU usage to request. Candidates to lower CPU requests."
    },
    {
      "id": 13,
      "title": "No CPU request set (but using CPU)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "sum by (namespace,pod,container)(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\", container!=\"POD\"}[$__rate_interval])) > 0 unless on(namespace,pod,container) kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"cpu\"}",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "description": "Containers consuming CPU with no request \u2014 unbounded scheduling risk."
    },
    {
      "id": 14,
      "title": "Highest memory limit:request ratio",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "topk(15, kube_pod_container_resource_limits{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"memory\"} / kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"memory\"})",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "description": "High ratio = burst headroom but OOM/eviction risk under pressure."
    }
  ],
  "refresh": "1m",
  "revision": 1,
  "schemaVersion": 39,
  "tags": [
    "kubernetes",
    "KubeMeridian",
    "cost",
    "finops"
  ],
