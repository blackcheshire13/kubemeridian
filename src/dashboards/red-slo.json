      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "KubeGraf \u2014 RED & SLO",
  "uid": "kubegraf-red-slo",
  "weekStart": ""
}
