    {
      "id": 4,
      "title": "OOMKilled (last termination)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "max by (namespace,pod,container)(kube_pod_container_status_last_terminated_reason{cluster=~\"$cluster\",namespace=~\"$namespace\",reason=\"OOMKilled\"}) > 0",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
