        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "description": "Container-level OOMKilled. Child-process OOMs are not captured here."
    },
    {
      "id": 5,
      "title": "Failed jobs",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${PromDs}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "kube_job_failed{cluster=~\"$cluster\",namespace=~\"$namespace\"} > 0",
          "legendFormat": "__auto",
          "refId": "A",
          "range": false,
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
