      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${PromDs}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le,verb)(rate(apiserver_request_duration_seconds_bucket{job=\"$apiserver_job\",cluster=~\"$cluster\",verb!~\"WATCH|CONNECT\"}[$__rate_interval])))",
          "legendFormat": "{{verb}}",
          "refId": "A",
          "range": true,
          "instant": false
