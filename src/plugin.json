{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "KubeMeridian",
  "id": "devopstech-kubemeridian-app",
  "info": {
    "keywords": ["app", "kubernetes", "k8s"],
    "description": "Kubernetes cluster monitoring — revived KubeMeridian for modern Grafana",
    "author": {
      "name": "devopstech"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Clusters",
      "path": "/a/%PLUGIN_ID%/clusters",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    },
    { "type": "datasource", "name": "KubeMeridian Kubernetes", "path": "datasource/plugin.json" },
    { "type": "dashboard", "name": "Cluster Overview", "path": "dashboards/cluster-overview.json", "addToNav": false },
    { "type": "dashboard", "name": "Namespace Overview", "path": "dashboards/namespace-overview.json", "addToNav": false },
    { "type": "dashboard", "name": "Workload Health", "path": "dashboards/workload-health.json", "addToNav": false },
    { "type": "dashboard", "name": "Storage", "path": "dashboards/storage.json", "addToNav": false },
    { "type": "dashboard", "name": "Cost & Efficiency", "path": "dashboards/cost-efficiency.json", "addToNav": false },
    { "type": "dashboard", "name": "Control Plane", "path": "dashboards/control-plane.json", "addToNav": false },
    { "type": "dashboard", "name": "Networking", "path": "dashboards/networking.json", "addToNav": false },
    { "type": "dashboard", "name": "Node", "path": "dashboards/node.json", "addToNav": false },
    { "type": "dashboard", "name": "Pod resources", "path": "dashboards/pod-resources.json", "addToNav": false },
    { "type": "dashboard", "name": "Deployment", "path": "dashboards/deployment.json", "addToNav": false },
    { "type": "dashboard", "name": "StatefulSet", "path": "dashboards/statefulset.json", "addToNav": false },
    { "type": "dashboard", "name": "DaemonSet", "path": "dashboards/daemonset.json", "addToNav": false }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
